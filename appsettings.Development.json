{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "FileVault",
    "GridFsBucketName": "fileVaultFiles"
  },
  "AppSettings": {
    "SiteName": "FileVault",
    "MaxChunkSizeBytes": 5242880,
    "UploadSessionExpiryMinutes": 1440,
    "ShareLinkDefaultExpiryDays": 7,
    "TempUploadPath": "temp_uploads",
    "AllowedFileExtensions": "",
    "BlockedFileExtensions": ".exe,.bat,.cmd,.com,.msi,.scr,.pif",
    "EnableVirusScan": false
  }
}
