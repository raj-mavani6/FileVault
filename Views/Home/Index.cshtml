@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="fv-hero">
    <div class="fv-hero-bg"></div>
    <div class="container position-relative">
        <div class="row align-items-center min-vh-75 py-5">
            <div class="col-lg-7 fv-animate-slide-up">
                <div class="d-inline-flex align-items-center gap-2 badge fv-badge-accent mb-4 py-2 px-3">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>Military-Grade Cloud Encryption</span>
                </div>
                <h1 class="fv-hero-title">
                    Securely Store &amp;<br/>
                    <span class="fv-gradient-text">Share Everything</span><br/>
                    In One Vault.
                </h1>
                <p class="fv-hero-subtitle">
                    The next generation of private cloud storage. FileVault offers 
                    <strong>resumable, chunked uploads</strong> and secure link sharing 
                    with zero compromises on privacy.
                </p>
                <div class="d-flex gap-3 flex-wrap mb-5">
                    <a href="/Auth/Register" class="btn fv-btn-primary btn-lg px-5">
                        <i class="bi bi-rocket-takeoff-fill me-2"></i>Get Started Free
                    </a>
                    <a href="#features" class="btn fv-btn-outline btn-lg px-4">
                        <i class="bi bi-play-circle me-2"></i>Explore Features
                    </a>
                </div>
                

            </div>
            <div class="col-lg-5 d-none d-lg-block fv-animate-slide-up" style="animation-delay:0.2s;">
                <div class="fv-hero-visual-container">
                    <div class="fv-floating-card fv-float-1">
                        <div class="fv-float-icon bg-rose"><i class="bi bi-file-earmark-image"></i></div>
                        <div class="fv-float-body">
                            <strong>Photo_Vault.jpg</strong>
                            <small>2.4 MB · Just Now</small>
                        </div>
                    </div>
                    <div class="fv-floating-card fv-float-2">
                        <div class="fv-float-icon bg-emerald"><i class="bi bi-file-earmark-pdf"></i></div>
                        <div class="fv-float-body">
                            <strong>Work_Specs.pdf</strong>
                            <small>1.1 MB · 2m ago</small>
                        </div>
                    </div>
                    <div class="fv-floating-card fv-float-3">
                        <div class="fv-float-icon bg-amber"><i class="bi bi-file-earmark-play"></i></div>
                        <div class="fv-float-body">
                            <strong>Vacation.mp4</strong>
                            <small>45 MB · 5m ago</small>
                        </div>
                    </div>
                    <div class="fv-hero-main-shield">
                        <i class="bi bi-shield-fill-check"></i>
                        <div class="fv-shield-pulse"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="fv-section" id="features">
    <div class="container">
        <div class="text-center mb-5 fv-animate-on-scroll">
            <h2 class="fv-section-title">Everything You Need</h2>
            <p class="fv-section-subtitle">Powerful features designed for modern file management</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-cloud-arrow-up"></i></div>
                    <h5 class="fw-800">Chunked Uploads</h5>
                    <p class="opacity-75">Upload files of any size with resumable, chunked uploads. Pause and resume at will.</p>
                </div>
            </div>
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-folder2-open"></i></div>
                    <h5 class="fw-800">Folder Organization</h5>
                    <p class="opacity-75">Create nested folders, move files freely, and keep everything organized.</p>
                </div>
            </div>
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-share"></i></div>
                    <h5 class="fw-800">Secure Sharing</h5>
                    <p class="opacity-75">Generate password-protected, expiring share links for any file.</p>
                </div>
            </div>
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-eye"></i></div>
                    <h5 class="fw-800">In-Browser Preview</h5>
                    <p class="opacity-75">Preview images, PDFs, videos, audio, and code files directly in the browser.</p>
                </div>
            </div>
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-recycle"></i></div>
                    <h5 class="fw-800">Trash &amp; Restore</h5>
                    <p class="opacity-75">Soft-delete files to Trash and restore them when needed. Permanent delete when ready.</p>
                </div>
            </div>
            <div class="col-md-4 fv-animate-on-scroll">
                <div class="fv-feature-card text-center">
                    <div class="fv-feature-icon mx-auto"><i class="bi bi-shield-check"></i></div>
                    <h5 class="fw-800">SHA-256 Integrity</h5>
                    <p class="opacity-75">Every file is verified with SHA-256 hash to ensure data integrity.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="fv-cta-section">
    <div class="container text-center fv-animate-on-scroll">
        <h2 class="fv-section-title">Ready to Secure Your Files?</h2>
        <p class="fv-section-subtitle mb-4">Create your free account and start uploading in seconds.</p>
        <a href="/Auth/Register" class="btn fv-btn-primary btn-lg fv-btn-glow">
            <i class="bi bi-box-arrow-in-right me-2"></i>Create Free Account
        </a>
    </div>
</section>

@section Scripts {
<script src="~/js/dashboard.js"></script>
}
