@model FileListViewModel
@{ Layout = "_AppLayout"; ViewData["Title"] = "My Files"; }

<div class="fv-page-top mb-4">
    <div>
        <h1 class="fv-heading">My Files</h1>
        <!-- Breadcrumbs -->
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb fv-breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Files" class="fv-link text-decoration-none"><i class="bi bi-hdd-fill me-1"></i>Root</a></li>
                @foreach (var bc in Model.Breadcrumbs)
                {
                    <li class="breadcrumb-item"><a href="/Files?folderId=@bc.Id" class="fv-link text-decoration-none">@bc.Name</a></li>
                }
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <button class="btn fv-btn-outline btn-sm" data-bs-toggle="modal" data-bs-target="#createFolderModal">
            <i class="bi bi-folder-plus me-1"></i>New Folder
        </button>
        <a href="/Files/Upload@(Model.CurrentFolderId != null ? $"?folderId={Model.CurrentFolderId}" : "")" class="btn fv-btn-primary btn-sm">
            <i class="bi bi-cloud-arrow-up me-1"></i>Upload
        </a>
    </div>
</div>

<!-- Search & Filter Bar -->
<div class="fv-card p-3 mb-4">
    <form method="get" class="row g-2 align-items-end">
        <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
        <div class="col-md-4">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control fv-input" placeholder="Search files..." />
        </div>
        <div class="col-md-2">
            <select name="ext" class="form-select fv-input">
                <option value="">All types</option>
                @foreach (var e in new[]{ ".pdf", ".jpg", ".png", ".mp4", ".docx", ".zip", ".txt" })
                {
                    <option value="@e" selected="@(Model.FilterExtension == e)">@e</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sortBy" class="form-select fv-input">
                <option value="">Date</option>
                <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                <option value="size" selected="@(Model.SortBy == "size")">Size</option>
                <option value="type" selected="@(Model.SortBy == "type")">Type</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn fv-btn-primary w-100"><i class="bi bi-search me-1"></i>Filter</button>
        </div>
    </form>
</div>

<!-- Folders -->
@if (Model.Folders.Any())
{
    <div class="row g-3 mb-4">
        @foreach (var folder in Model.Folders)
        {
            <div class="col-6 col-md-3 col-lg-2 fv-animate-fade-in">
                <a href="/Files?folderId=@folder.Id" class="fv-folder-card text-decoration-none">
                    <i class="bi bi-folder-fill fs-2 tw-text-accent"></i>
                    <span class="fv-folder-name">@folder.Name</span>
                    <div class="fv-folder-actions" onclick="event.preventDefault();event.stopPropagation();">
                        <button class="btn btn-sm fv-btn-icon" onclick="renameFolder('@folder.Id','@folder.Name')"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-sm fv-btn-icon text-danger" onclick="deleteFolder('@folder.Id')"><i class="bi bi-trash"></i></button>
                    </div>
                </a>
            </div>
        }
    </div>
}

<!-- Files -->
@if (Model.Files.Any())
{
    <div class="fv-card">
        <div class="table-responsive">
            <table class="table fv-table mb-0">
                <thead><tr><th>Name</th><th>Size</th><th>Type</th><th>Date</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                @foreach (var file in Model.Files)
                {
                    <tr class="fv-animate-fade-in">
                        <td>
                            <a href="/Files/Details/@file.Id" class="fv-link text-decoration-none">
                                <i class="bi @file.FileIcon me-2 tw-text-accent"></i>@file.FileName
                            </a>
                        </td>
                        <td class="fv-text-muted">@file.SizeFormatted</td>
                        <td class="fv-text-muted">@file.Extension</td>
                        <td class="fv-text-muted">@file.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <a href="/Files/Details/@file.Id" class="btn btn-sm fv-btn-icon" title="View Details"><i class="bi bi-eye"></i></a>
                            <a href="/Files/Download/@file.Id" class="btn btn-sm fv-btn-icon" title="Download"><i class="bi bi-download"></i></a>
                            <button class="btn btn-sm fv-btn-icon" onclick="shareFile('@file.Id')" title="Share"><i class="bi bi-share"></i></button>
                            <button class="btn btn-sm fv-btn-icon text-danger" onclick="deleteFile('@file.Id')" title="Delete"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="fv-pagination p-3">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <a href="/Files?folderId=@Model.CurrentFolderId&page=@p&sortBy=@Model.SortBy&search=@Model.SearchTerm&ext=@Model.FilterExtension"
                       class="btn btn-sm @(p == Model.Page ? "fv-btn-primary" : "fv-btn-outline")">@p</a>
                }
            </div>
        }
    </div>
}
else if (!Model.Folders.Any())
{
    <div class="fv-card p-5">
        <div class="fv-empty-state">
            <i class="bi bi-folder-x fs-1"></i>
            <h5 class="mt-3">No files here</h5>
            <p class="fv-text-muted">Upload some files or create a folder to get started.</p>
            <a href="/Files/Upload@(Model.CurrentFolderId != null ? $"?folderId={Model.CurrentFolderId}" : "")" class="btn fv-btn-primary">
                <i class="bi bi-cloud-arrow-up me-2"></i>Upload Files
            </a>
        </div>
    </div>
}

<!-- Create Folder Modal -->
<div class="modal fade" id="createFolderModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content fv-modal">
        <div class="modal-header border-0"><h5 class="modal-title">New Folder</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <input type="text" id="newFolderName" class="form-control fv-input" placeholder="Folder name" />
        </div>
        <div class="modal-footer border-0">
            <button class="btn fv-btn-outline" data-bs-dismiss="modal">Cancel</button>
            <button class="btn fv-btn-primary" onclick="createFolder()">Create</button>
        </div>
    </div></div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content fv-modal">
        <div class="modal-header border-0"><h5 class="modal-title">Share File</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <input type="hidden" id="shareFileId" />
            <div class="mb-3"><label class="fv-label">Expiry (days)</label><input type="number" id="shareExpiry" class="form-control fv-input" value="7" min="1" /></div>
            <div class="mb-3"><label class="fv-label">Password (optional)</label><input type="password" id="sharePassword" class="form-control fv-input" /></div>
            <div class="form-check mb-3"><input type="checkbox" id="shareAllowDownload" class="form-check-input" checked /><label class="form-check-label fv-text-muted">Allow download</label></div>
            <div id="shareResult" class="d-none">
                <label class="fv-label">Share Link</label>
                <div class="input-group"><input type="text" id="shareUrl" class="form-control fv-input" readonly /><button class="btn fv-btn-primary" onclick="copyShareUrl()"><i class="bi bi-clipboard"></i></button></div>
            </div>
        </div>
        <div class="modal-footer border-0">
            <button class="btn fv-btn-outline" data-bs-dismiss="modal">Close</button>
            <button class="btn fv-btn-primary" id="shareCreateBtn" onclick="createShareLink()">Generate Link</button>
        </div>
    </div></div>
</div>

@section Scripts {
<script src="~/js/files.js"></script>
<script src="~/js/dashboard.js"></script>
<script>const currentFolderId = '@(Model.CurrentFolderId ?? "")';</script>
}
