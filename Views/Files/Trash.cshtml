@model FileListViewModel
@{ Layout = "_AppLayout"; ViewData["Title"] = "Trash"; }
<div class="fv-page-top mb-4">
    <h1 class="fv-heading"><i class="bi bi-trash3 me-2"></i>Trash</h1>
    @if (Model.Files.Any()) { <button class="btn fv-btn-outline btn-sm text-danger" onclick="emptyTrash()"><i class="bi bi-trash me-1"></i>Empty Trash</button> }
</div>
@if (Model.Files.Any() || Model.Folders.Any())
{
    @if (Model.Folders.Any())
    {
        <div class="fv-card mb-4">
            <div class="table-responsive">
                <table class="table fv-table mb-0">
                    <thead><tr><th>Folder Name</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
                    <tbody>
                    @foreach (var f in Model.Folders)
                    {
                        <tr class="fv-animate-fade-in">
                            <td><i class="bi bi-folder-fill me-2 tw-text-accent"></i>@f.Name</td>
                            <td class="fv-text-muted">@f.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <button class="btn btn-sm fv-btn-icon" onclick="restoreFolder('@f.Id')" title="Restore"><i class="bi bi-arrow-counterclockwise"></i></button>
                                <button class="btn btn-sm fv-btn-icon text-danger" onclick="permanentDeleteFolder('@f.Id')" title="Delete Permanently"><i class="bi bi-x-lg"></i></button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Model.Files.Any())
    {
        <div class="fv-card"><div class="table-responsive"><table class="table fv-table mb-0">
            <thead><tr><th>File Name</th><th>Size</th><th>Deleted</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var f in Model.Files)
            {
                <tr class="fv-animate-fade-in">
                    <td><i class="bi @f.FileIcon me-2 tw-text-accent"></i>@f.FileName</td>
                    <td class="fv-text-muted">@f.SizeFormatted</td>
                    <td class="fv-text-muted">@(f.DeletedAt?.ToString("MMM dd, yyyy") ?? "-")</td>
                    <td class="text-end">
                        <button class="btn btn-sm fv-btn-icon" onclick="restoreFile('@f.Id')" title="Restore"><i class="bi bi-arrow-counterclockwise"></i></button>
                        <button class="btn btn-sm fv-btn-icon text-danger" onclick="permanentDelete('@f.Id')" title="Delete Permanently"><i class="bi bi-x-lg"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table></div></div>
    }
}
else
{
    <div class="fv-card p-5"><div class="fv-empty-state"><i class="bi bi-trash fs-1"></i><h5 class="mt-3">Trash is empty</h5><p class="fv-text-muted">Deleted files will appear here.</p></div></div>
}
@section Scripts { <script src="~/js/files.js"></script> }
