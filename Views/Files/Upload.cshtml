@{ Layout = "_AppLayout"; ViewData["Title"] = "Upload Files"; }
<div class="fv-page-top mb-4"><h1 class="fv-heading">Upload Center</h1></div>
<div class="fv-card p-4 mb-4">
    <div id="dropZone" class="fv-drop-zone">
        <i class="bi bi-cloud-arrow-up fs-1 tw-text-accent"></i>
        <h5 class="mt-3">Drag &amp; drop files here</h5>
        <p class="fv-text-muted">or click to browse</p>
        <input type="file" id="fileInput" multiple class="d-none" />
        <button class="btn fv-btn-outline" onclick="document.getElementById('fileInput').click()">
            <i class="bi bi-folder2-open me-2"></i>Browse Files
        </button>
    </div>
</div>
<div id="uploadList" class="fv-card p-4 d-none">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="bi bi-list-task me-2"></i>Upload Queue</h5>
        <div class="d-flex gap-2">
            <button class="btn btn-sm fv-btn-outline" onclick="pauseAll()"><i class="bi bi-pause-fill me-1"></i>Pause All</button>
            <button class="btn btn-sm fv-btn-primary" onclick="resumeAll()"><i class="bi bi-play-fill me-1"></i>Resume All</button>
        </div>
    </div>
    <div id="uploadItems"></div>
</div>

@section Scripts {
<script>const uploadFolderId = '@(ViewBag.FolderId ?? "")';</script>
<script src="~/js/upload.js"></script>
}
