@model FileItemViewModel
@{ Layout = "_AppLayout"; ViewData["Title"] = Model.FileName; }
<div class="fv-page-top mb-4">
    <div>
        <h1 class="fv-heading"><i class="bi @Model.FileIcon me-2 tw-text-accent"></i>@Model.FileName</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb fv-breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Files" class="fv-link text-decoration-none">My Files</a></li>
                <li class="breadcrumb-item active">@Model.FileName</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a href="/Files/Preview/@Model.Id" target="_blank" class="btn fv-btn-outline"><i class="bi bi-eye me-1"></i>Preview</a>
        <a href="/Files/Download/@Model.Id" class="btn fv-btn-primary"><i class="bi bi-download me-1"></i>Download</a>
        <button class="btn fv-btn-outline" onclick="shareFile('@Model.Id')">
            <i class="bi bi-share me-1"></i>Share
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Preview Area -->
        <div class="fv-card overflow-hidden" style="min-height: 500px; display: flex; flex-direction: column;">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-dark bg-opacity-10">
                <span class="small fw-600 opacity-75"><i class="bi bi-eye me-2"></i>File Preview</span>
                <span class="badge fv-badge-accent">@Model.ContentType</span>
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-center bg-black bg-opacity-50" style="min-height: 540px;">
                @{
                    var ext = (Model.Extension ?? "").ToLowerInvariant().TrimStart('.');
                    var isOffice = new[] { "doc", "docx", "xls", "xlsx", "ppt", "pptx" }.Contains(ext);
                    var isArchive = new[] { "zip", "rar", "7z", "tar", "gz", "bz2" }.Contains(ext);
                    var isCode = new[] { "json", "css", "js", "ts", "py", "cs", "java", "cpp", "sql", "sh", "xml", "yaml", "yml", "bat", "ini", "conf", "env", "md", "log", "csproj", "sln", "go", "rs", "php", "rb", "txt" }.Contains(ext);
                }

                @if (Model.ContentType.StartsWith("image/"))
                {
                    <img src="/Files/Preview/@Model.Id" class="img-fluid fv-animate-fade-in" style="max-height: 600px; object-fit: contain;" alt="@Model.FileName" />
                }
                else if (Model.ContentType.StartsWith("video/"))
                {
                    <video controls class="w-100 fv-animate-fade-in" style="max-height: 600px; background: #000;">
                        <source src="/Files/Preview/@Model.Id" type="@Model.ContentType">
                        Your browser does not support the video tag.
                    </video>
                }
                else if (Model.ContentType.StartsWith("audio/"))
                {
                    <div class="text-center w-100 p-5 fv-animate-fade-in">
                        <i class="bi bi-music-note-beamed display-1 tw-text-accent opacity-25 mb-4 d-block"></i>
                        <audio controls class="w-75 mx-auto">
                            <source src="/Files/Preview/@Model.Id" type="@Model.ContentType">
                        </audio>
                    </div>
                }
                else if (Model.ContentType == "application/pdf" || ext == "pdf")
                {
                    <iframe src="/Files/Preview/@Model.Id#toolbar=0" width="100%" height="600px" style="border:none;" class="fv-animate-fade-in"></iframe>
                }
                else if (isOffice)
                {
                    var isLocal = Context.Request.Host.Host.Contains("localhost") || Context.Request.Host.Host.Contains("127.0.0.1") || Context.Request.Host.Host.StartsWith("192.168.") || Context.Request.Host.Host.StartsWith("10.") || Context.Request.Host.Host.Contains("::1");
                    if (isLocal && (ext == "docx" || ext == "doc"))
                    {
                        <div class="w-100 p-4 fv-animate-fade-in bg-white text-dark rounded-3 mx-3 my-4" id="docxPreview" style="max-height:600px; overflow-y:auto; min-height:400px; font-family: 'Segoe UI', serif;">
                            <div class="text-center py-5 opacity-25" id="docxLoader">
                                <div class="spinner-border text-primary" role="status"></div>
                                <div class="mt-2 small fw-700">Extracting Document Layer... @(ext.ToUpper())</div>
                            </div>
                        </div>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
                        <script>
                            fetch('/Files/Preview/@Model.Id')
                                .then(r => r.arrayBuffer())
                                .then(arrayBuffer => {
                                    mammoth.convertToHtml({ arrayBuffer: arrayBuffer })
                                        .then(result => {
                                            document.getElementById('docxPreview').innerHTML = result.value || '<div class="text-center p-5 text-muted">Empty Document</div>';
                                        })
                                        .catch(err => {
                                            document.getElementById('docxPreview').innerHTML = '<div class="alert alert-danger">Local Rendering Error: ' + err.message + '<br/><small>Showing raw text instead...</small></div>';
                                            fetch('/Files/Preview/@Model.Id').then(r=>r.text()).then(t => { 
                                                document.getElementById('docxPreview').innerHTML += `<pre style="font-size:0.7rem; opacity:0.5">${t.substring(0, 1000)}</pre>`;
                                            });
                                        });
                                });
                        </script>
                    }
                    else if (isLocal)
                    {
                        <div class="w-100 p-4 fv-animate-fade-in" id="officeStage" style="max-height:600px; overflow-y:auto;">
                            <div class="fv-card bg-warning bg-opacity-10 p-5 d-block text-center" id="officeLocalBox" style="border: 2px dashed var(--accent);">
                                <div id="officeIconBox">
                                    <i class="bi bi-file-earmark-ppt-fill display-1 text-warning mb-4"></i>
                                    <h4 class="fw-700">Deep Inspection Mode (Local)</h4>
                                    <p class="text-muted small mb-4">Cloud rendering for <b>.@ext.ToUpper()</b> is restricted on local hosts.</p>
                                </div>
                                <a href="/Files/Download/@Model.Id" class="btn btn-sm fv-btn-primary px-4"><i class="bi bi-download me-2"></i>Download File</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="w-100 h-100 fv-animate-fade-in" style="min-height:600px;">
                            @{ var publicUrl = Uri.EscapeDataString($"{Context.Request.Scheme}://{Context.Request.Host}/Files/Preview/{Model.Id}"); }
                            <iframe src="https://view.officeapps.live.com/op/embed.aspx?src=@publicUrl" width="100%" height="600px" style="border:none; background:#fff;"></iframe>
                            <div class="p-2 text-center small opacity-50"><i class="bi bi-shield-check me-1"></i> Rendered via Microsoft Office Online Viewer</div>
                        </div>
                    }
                }
                else if (isArchive)
                {
                    <div class="w-100 p-4 fv-animate-fade-in" id="archivePreview" style="max-height:600px; overflow-y:auto;">
                        <h6 class="tw-text-accent mb-3"><i class="bi bi-folder2-open me-2"></i>Archive Metadata Index</h6>
                        <div id="archiveContent" class="opacity-75 small font-monospace">
                            <div class="spinner-border spinner-border-sm text-accent" role="status"></div> Investigating...
                        </div>
                    </div>
                    <script>
                        fetch('/Files/GetArchiveContents/@Model.Id')
                            .then(r => r.json())
                            .then(data => {
                                const cont = document.getElementById('archiveContent');
                                if (!data || data.length === 0) cont.innerHTML = "No files found or protected archive.";
                                else cont.innerHTML = data.map(f => `<div class="border-bottom border-secondary border-opacity-10 py-1"><i class="bi bi-file-earmark me-2 opacity-50"></i>${f}</div>`).join('');
                            });
                    </script>
                }
                else if (Model.ContentType.StartsWith("text/") || isCode || (!isOffice && !isArchive && !Model.ContentType.StartsWith("image") && !Model.ContentType.StartsWith("video") && !Model.ContentType.StartsWith("audio") && Model.ContentType != "application/pdf" && ext != "pdf"))
                {
                    <div class="w-100 p-4 font-monospace small text-white-50 fv-animate-fade-in" id="codePreview" style="max-height:600px; overflow-y:auto; white-space:pre-wrap; background: #0c0b0a;">
                        <div class="d-flex justify-content-between align-items-center mb-3 opacity-25">
                            <span class="small font-monospace">SOURCE READER (UNIVERSAL)</span>
                            <i class="bi bi-file-earmark-code fs-4"></i>
                        </div>
                        @if (Model.SizeBytes > 1024 * 1024)
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-exclamation-triangle display-4 text-warning mb-3 d-block"></i>
                                <div class="fw-700">Large Data Stream detected (@Model.SizeFormatted)</div>
                                <div class="small opacity-50 mb-4">Preview is limited to the first 1MB for stability.</div>
                                <button class="btn btn-sm btn-outline-warning" onclick="loadPartialRaw()">Inspect Data</button>
                            </div>
                        }
                        <div id="codeContent" class="opacity-75">@(Model.SizeBytes > 1024 * 1024 ? "" : "Loading content...")</div>
                    </div>
                    <script>
                        function loadPartialRaw() {
                            document.getElementById('codeContent').textContent = "Streaming first 1MB...";
                            fetch('/Files/Preview/@Model.Id').then(r => r.text()).then(t => { document.getElementById('codeContent').textContent = t.substring(0, 1000000); });
                        }
                        if (@(Model.SizeBytes <= 1024 * 1024 ? "true" : "false")) {
                            fetch('/Files/Preview/@Model.Id')
                                .then(r => r.text())
                                .then(t => { document.getElementById('codeContent').textContent = t; })
                                .catch(e => { document.getElementById('codeContent').textContent = "Failed to load raw stream."; });
                        }
                    </script>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="fv-card p-4 h-100">
            <h6 class="mb-4 pb-2 border-bottom border-light border-opacity-10">File Properties</h6>
            <div class="mb-3">
                <small class="tw-text-muted d-block mb-1">Full Name</small>
                <div class="fw-600">@Model.FileName</div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <small class="tw-text-muted d-block mb-1">Size</small>
                    <div class="fw-500">@Model.SizeFormatted</div>
                </div>
                <div class="col-6">
                    <small class="tw-text-muted d-block mb-1">Type</small>
                    <div class="badge fv-badge-accent">@Model.Extension.ToUpper().Replace(".","")</div>
                </div>
            </div>
            <div class="mb-3">
                <small class="tw-text-muted d-block mb-1">Last Updated</small>
                <div class="fw-500">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
            <div class="mb-4">
                <small class="tw-text-muted d-block mb-1">Version Control</small>
                <div class="fw-500"><i class="bi bi-stack me-2"></i>v@Model.VersionNumber</div>
            </div>
            
            @if (Model.Tags.Any())
            {
                <div class="mt-3">
                    <small class="tw-text-muted d-block mb-2">Metadata Tags</small>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach(var t in Model.Tags) { <span class="badge bg-secondary bg-opacity-25 text-white-50">@t</span> }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content fv-modal">
        <div class="modal-header border-0"><h5 class="modal-title"><i class="bi bi-share me-2"></i>Share File</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <input type="hidden" id="shareFileId" />
            <div class="mb-3"><label class="fv-label">Expiry (days)</label><input type="number" id="shareExpiry" class="form-control fv-input" value="7" min="1" /></div>
            <div class="mb-3"><label class="fv-label">Password (optional)</label><input type="password" id="sharePassword" class="form-control fv-input" /></div>
            <div class="form-check mb-3"><input type="checkbox" id="shareAllowDownload" class="form-check-input" checked /><label class="form-check-label fv-text-muted">Allow download</label></div>
            <div id="shareResult" class="d-none">
                <label class="fv-label">Share Link</label>
                <div class="input-group"><input type="text" id="shareUrl" class="form-control fv-input" readonly /><button class="btn fv-btn-primary" onclick="copyShareUrl()"><i class="bi bi-clipboard"></i></button></div>
            </div>
        </div>
        <div class="modal-footer border-0">
            <button class="btn fv-btn-outline" data-bs-dismiss="modal">Close</button>
            <button class="btn fv-btn-primary" id="shareCreateBtn" onclick="createShareLink()">Generate Link</button>
        </div>
    </div></div>
</div>

@section Scripts {
<script src="~/js/files.js"></script>
}
