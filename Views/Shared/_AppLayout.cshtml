@using System.Security.Claims
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Dashboard") — FileVault</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="~/css/tailwind-output.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="fv-body">
    <div class="fv-app-wrapper">
        <!-- Sidebar -->
        <aside class="fv-sidebar" id="sidebar">
            <div class="fv-sidebar-header">
                <a class="fv-brand" href="/Dashboard">
                    <i class="bi bi-shield-lock-fill tw-text-accent"></i>
                    <span>FileVault</span>
                </a>
            </div>
            <nav class="fv-sidebar-nav">
                <a href="/Dashboard" class="fv-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                </a>
                <a href="/Files" class="fv-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Files" && ViewContext.RouteData.Values["action"]?.ToString() != "Trash" && ViewContext.RouteData.Values["action"]?.ToString() != "Upload" ? "active" : "")">
                    <i class="bi bi-folder-fill"></i><span>My Files</span>
                </a>
                <a href="/Files/Upload" class="fv-sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Upload" ? "active" : "")">
                    <i class="bi bi-cloud-arrow-up-fill"></i><span>Upload</span>
                </a>
                <a href="/Files/Trash" class="fv-sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Trash" ? "active" : "")">
                    <i class="bi bi-trash3-fill"></i><span>Trash</span>
                </a>
                <a href="/Profile" class="fv-sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="bi bi-person-fill"></i><span>Profile</span>
                </a>

            </nav>
        </aside>

        <!-- Main Content -->
        <div class="fv-main">
            <!-- Top Bar -->
            <header class="fv-topbar">
                <button class="btn fv-btn-icon d-lg-none" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="fv-topbar-spacer"></div>
                <div class="d-flex align-items-center gap-3">
                    <button id="appThemeToggle" class="btn fv-btn-icon" title="Toggle theme">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    <div class="dropdown">
                        <button class="btn fv-user-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <div class="fv-avatar-sm">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span>@User.FindFirstValue(ClaimTypes.Name)</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end fv-dropdown">
                            <li><a class="dropdown-item" href="/Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="fv-content">
                <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100;"></div>
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('show');
        });
    </script>

    @if (TempData["Success"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Success"]', 'success'));</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Error"]', 'danger'));</script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
