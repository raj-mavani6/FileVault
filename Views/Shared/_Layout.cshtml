<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FileVault - Secure cloud file storage. Upload, organize, share, and manage your files with ease." />
    <title>@(ViewData["Title"] ?? "FileVault") — Secure Cloud Storage</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Tailwind Output -->
    <link href="~/css/tailwind-output.css" rel="stylesheet" />
    <!-- Custom Styles -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="fv-body">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fv-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand fv-brand" href="/">
                <i class="bi bi-shield-lock-fill tw-text-accent"></i>
                <span>FileVault</span>
            </a>
            <button class="navbar-toggler fv-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <i class="bi bi-list"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link fv-nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link fv-nav-link" href="/Home/Features">Features</a></li>
                    <li class="nav-item"><a class="nav-link fv-nav-link" href="/Home/About">About</a></li>
                    <li class="nav-item"><a class="nav-link fv-nav-link" href="/Home/Contact">Contact</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <button id="themeToggle" class="btn fv-btn-icon" title="Toggle theme">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Dashboard" class="btn fv-btn-primary">
                            <i class="bi bi-grid-fill me-1"></i> Dashboard
                        </a>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn fv-btn-outline">Sign In</a>
                        <a href="/Auth/Register" class="btn fv-btn-primary">Get Started</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100;"></div>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="fv-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="fv-brand mb-3">
                        <i class="bi bi-shield-lock-fill tw-text-accent"></i>
                        <span>FileVault</span>
                    </div>
                    <p class="fv-text-muted">Secure, modern file storage for everyone. Upload, organize, and share files effortlessly.</p>
                </div>
                <div class="col-lg-2">
                    <h6 class="fv-footer-heading">Product</h6>
                    <ul class="list-unstyled fv-footer-links">
                        <li><a href="/Home/Features">Features</a></li>
                        <li><a href="/Home/About">About</a></li>
                        <li><a href="/Home/Contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h6 class="fv-footer-heading">Legal</h6>
                    <ul class="list-unstyled fv-footer-links">
                        <li><a href="/Home/Privacy">Privacy Policy</a></li>
                        <li><a href="/Home/Terms">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="fv-footer-heading">Contact Us</h6>
                    <ul class="list-unstyled fv-footer-links small">
                        <li class="mb-2"><i class="bi bi-envelope-at me-2 text-accent"></i>support@filevault.io</li>
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-accent"></i>Silicon Valley, California</li>
                        <li><i class="bi bi-chat-left-dots me-2 text-accent"></i>Mon - Fri, 9am - 5pm EST</li>
                    </ul>
                </div>
            </div>
            <hr class="fv-divider" />
            <p class="text-center fv-text-muted small mb-0">&copy; @DateTime.Now.Year FileVault. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Theme & Toast Scripts -->
    <script src="~/js/theme.js"></script>
    <script src="~/js/site.js"></script>

    @if (TempData["Success"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Success"]', 'success'));</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Error"]', 'danger'));</script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
