@model ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; }
<section class="fv-auth-section"><div class="container"><div class="row justify-content-center"><div class="col-md-5 fv-animate-slide-up">
<div class="fv-card fv-auth-card p-4 p-md-5">
    <div class="text-center mb-4"><i class="bi bi-key fs-1 tw-text-accent"></i><h2 class="mt-2">Reset Password</h2></div>
    <form asp-action="ResetPassword" method="post">@Html.AntiForgeryToken()
        <input type="hidden" asp-for="Token" />
        <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
        <div class="mb-3"><label class="fv-label">New Password</label><input asp-for="NewPassword" class="form-control fv-input" /><span asp-validation-for="NewPassword" class="text-danger small"></span></div>
        <div class="mb-4"><label class="fv-label">Confirm</label><input asp-for="ConfirmPassword" class="form-control fv-input" /><span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
        <button type="submit" class="btn fv-btn-primary w-100"><i class="bi bi-check-lg me-2"></i>Reset Password</button>
    </form>
</div></div></div></div></section>
