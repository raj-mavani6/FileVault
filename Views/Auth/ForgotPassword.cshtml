@model ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; }
<section class="fv-auth-section"><div class="container"><div class="row justify-content-center"><div class="col-md-5 fv-animate-slide-up">
<div class="fv-card fv-auth-card p-4 p-md-5">
    <div class="text-center mb-4"><i class="bi bi-envelope-open fs-1 tw-text-accent"></i><h2 class="mt-2">Forgot Password</h2><p class="fv-text-muted">Enter your email to receive a reset link</p></div>
    <form asp-action="ForgotPassword" method="post">@Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
        <div class="mb-4"><label class="fv-label">Email</label><input asp-for="Email" class="form-control fv-input" placeholder="you@example.com" /><span asp-validation-for="Email" class="text-danger small"></span></div>
        <button type="submit" class="btn fv-btn-primary w-100 mb-3"><i class="bi bi-send me-2"></i>Send Reset Link</button>
        <p class="text-center fv-text-muted small"><a href="/Auth/Login" class="fv-link">Back to Sign In</a></p>
    </form>
</div></div></div></div></section>
