@model RegisterViewModel
@{ ViewData["Title"] = "Create Account"; }
<section class="fv-auth-section">
    <div class="container"><div class="row justify-content-center"><div class="col-md-5 fv-animate-slide-up">
        <div class="fv-card fv-auth-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus-fill fs-1 tw-text-accent"></i>
                <h2 class="mt-2">Create Account</h2>
                <p class="fv-text-muted">Start storing your files securely</p>
            </div>
            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                <div class="mb-3"><label class="fv-label">Full Name</label>
                    <input asp-for="FullName" class="form-control fv-input" placeholder="John Doe" />
                    <span asp-validation-for="FullName" class="text-danger small"></span></div>
                <div class="mb-3"><label class="fv-label">Email</label>
                    <input asp-for="Email" class="form-control fv-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span></div>
                <div class="mb-3"><label class="fv-label">Password</label>
                    <input asp-for="Password" class="form-control fv-input" placeholder="Min. 6 characters" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span></div>
                <div class="mb-4"><label class="fv-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" class="form-control fv-input" placeholder="Repeat password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
                <button type="submit" class="btn fv-btn-primary w-100 mb-3"><i class="bi bi-person-plus me-2"></i>Create Account</button>
                <p class="text-center fv-text-muted small mb-0">Already have an account? <a href="/Auth/Login" class="fv-link">Sign in</a></p>
            </form>
        </div>
    </div></div></div>
</section>
