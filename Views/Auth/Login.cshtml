@model LoginViewModel
@{ ViewData["Title"] = "Sign In"; }
<section class="fv-auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 fv-animate-slide-up">
                <div class="fv-card fv-auth-card p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock-fill fs-1 tw-text-accent"></i>
                        <h2 class="mt-2">Welcome Back</h2>
                        <p class="fv-text-muted">Sign in to access your files</p>
                    </div>
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                        <div class="mb-3">
                            <label class="fv-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text fv-input-icon"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control fv-input" placeholder="you@example.com" autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="fv-label">Password</label>
                            <div class="input-group">
                                <span class="input-group-text fv-input-icon"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" class="form-control fv-input" placeholder="••••••••" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label class="form-check-label fv-text-muted small" asp-for="RememberMe">Remember me</label>
                            </div>
                            <a href="/Auth/ForgotPassword" class="fv-link small">Forgot password?</a>
                        </div>
                        <button type="submit" class="btn fv-btn-primary w-100 mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                        <p class="text-center fv-text-muted small mb-0">
                            Don't have an account? <a href="/Auth/Register" class="fv-link">Create one</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
